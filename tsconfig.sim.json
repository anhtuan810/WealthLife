{
  "compilerOptions": {
    "target": "ES2022",
    "module": "node16",
    "moduleResolution": "node16",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "isolatedModules": false,
    "noEmit": false,
    "outDir": ".sim-build",
    "rootDir": ".",
    "lib": ["ES2022", "DOM"]
  },
  "include": [
    "src/sim/**/*.ts",
    "src/data/**/*.ts",
    "src/game/**/*.ts",
    "src/content/**/*.ts",
    "src/systems/**/*.ts",
    "src/personalization/**/*.ts",
    "src/types/events.ts",
    "scripts/**/*.ts"
  ]
}
